{
  "name": "expo-tuya-sdk",
  "version": "0.1.0",
  "description": "Expo module wrapping the Tuya (Thing) Smart Home SDK for iOS and Android — home management, device pairing, device sharing, and user account.",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "scripts": {
    "build": "expo-module build",
    "build:plugin": "tsc --project plugin/tsconfig.json",
    "clean": "expo-module clean",
    "lint": "ESLINT_USE_FLAT_CONFIG=false expo-module lint",
    "typecheck": "tsc --noEmit",
    "test": "expo-module test",
    "prepare": "expo-module prepare && npm run build:plugin",
    "prepublishOnly": "expo-module prepublishOnly",
    "expo-module": "expo-module",
    "open:ios": "xed example/ios",
    "open:android": "open -a \"Android Studio\" example/android"
  },
  "keywords": [
    "react-native",
    "expo",
    "expo-module",
    "tuya",
    "thing-sdk",
    "smart-home",
    "iot",
    "device-pairing",
    "home-management",
    "device-sharing"
  ],
  "expo": {
    "configPlugin": "./plugin/build/index.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/traildevbr/expo-tuya-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/traildevbr/expo-tuya-sdk/issues"
  },
  "author": "Traildev Team <contato@traildev.com.br> (https://github.com/traildevbr)",
  "license": "MIT",
  "homepage": "https://github.com/traildevbr/expo-tuya-sdk#readme",
  "files": [
    "build",
    "android/src",
    "android/build.gradle",
    "ios/**/*.swift",
    "ios/**/*.h",
    "ios/**/*.m",
    "plugin/build",
    "app.plugin.js",
    "expo-module.config.json",
    "ExpoTuyaSdk.podspec",
    "LICENSE",
    "README.md"
  ],
  "dependencies": {
    "expo": "~55.0.15",
    "react": "19.2.0",
    "react-native": "0.83.4"
  },
  "devDependencies": {
    "@types/react": "~19.1.1",
    "expo-module-scripts": "^55.0.2",
    "expo": "^55.0.14",
    "react-native": "0.82.1"
  },
  "peerDependencies": {
    "expo": ">=51.0.0",
    "react": "*",
    "react-native": ">=0.74.0"
  }
}
